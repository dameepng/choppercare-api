# FastAPI app
DEBUG=true
APP_NAME=ChopperCare

# Groq
GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/choppercare

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001","https://choppercare.toeanmuda.id"]

# RAG
EMBED_MODEL=nomic-ai/nomic-embed-text-v1
TOP_K_RESULTS=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Rate limiting
RATE_LIMIT=30/minute
